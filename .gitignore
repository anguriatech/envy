# Rust build artifacts
/target
*.rs.bk
*.rlib
*.prof*

# IDE
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Local environment files (never commit plaintext secrets)
.env*

# SQLite database files (vault.db lives at ~/.envy/ outside the repo, but belt-and-suspenders)
*.db
*.db-shm
*.db-wal

# Note: .specify/ is intentionally tracked — it contains project specs and templates
# However, per-developer installation state is excluded so each dev can
# regenerate their own .opencode/, .claude/, etc. via `specify init . --ai=<agent>`

# Opencode (per-developer; each dev runs `specify init . --ai=<their-agent>` locally)
.opencode/

# Claude Code (legacy; was leaking user-specific config; now per-developer)
.claude/settings.json
.claude/settings.local.json

# Spec-kit: per-developer installation state (regenerated by `specify init .`)
.specify/integration.json
.specify/integrations/
.specify/workflows/
.specify/scripts/bash/setup-tasks.sh
